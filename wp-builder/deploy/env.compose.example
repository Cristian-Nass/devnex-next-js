# Optional: copy to repo root as `.env` on the server (same folder as docker-compose.yml).
# Compose interpolates these when you run `docker compose up`.

# Host path where per-tenant site directories are stored.
# Must match WEBSITES_ROOT in server/.env and the volume mount in docker-compose.yml.
WEBSITES_ROOT=/home/wordpress/websites

# wp-builder panel → nginx-proxy. Set ONE of these (same effect):
#   PANEL_VIRTUAL_HOST=wp.arvidn.dev
#   VIRTUAL_HOST=wp.arvidn.dev
# Match WEB_ORIGIN / Cloudflare DNS. Tenant URLs use server/.env ROOT_DOMAIN (e.g. *.arvidn.dev).

# PANEL_VIRTUAL_HOST=wp.arvidn.dev
