# Postgres URL — external DB only (nothing Postgres-related is defined in docker-compose.yml).
# - API on host (`npm run dev`): localhost is fine if Postgres listens locally.
# - API in Docker: use host.docker.internal, LAN IP, or your DB hostname (not localhost for DB on host unless DB shares network).
NODE_ENV=development
PORT=3001
# Must be PostgreSQL. Use postgresql://… (postgres:// is normalized automatically).
# Value must be only the URI after = — do not paste "DATABASE_URL=..." inside the value (Compose passes junk prefix otherwise).
DATABASE_URL="postgresql://user:password@host.docker.internal:5432/wpbuilder?schema=public"

# Web UI origin (Next.js dashboard, sibling app — see wp-builder/web/).
WEB_ORIGIN="http://localhost:3003"

# Netmart API base for /auth/introspect. Used by lib/platform-auth.ts to
# validate the `netmart_session` cookie sent by the dashboard. Include /api.
PLATFORM_API_URL="http://localhost:5000/api"

# Repo root as seen by the API process (Compose file + docker/php templates). In Docker use `/opt/wp-builder`.
REPO_ROOT="/opt/wp-builder"
# Per-site folders: WEBSITES_ROOT/<slug>/.env, wp/, mysql/, .wp-builder/php/
WEBSITES_ROOT="/home/wordpress/websites"
# Optional (Docker API as root): numeric UID/GID for the SSH user who runs `docker compose --env-file` (NOT shell commands).
# On the server: id -u wordpress    id -g wordpress    → paste those integers here (no quotes).
# WEBSITES_ENV_OWNER_UID=1000
# WEBSITES_ENV_OWNER_GID=1000

VIRTUAL_HOST="wp.arvidn.dev"

# Tenant site hostnames: <slug>.<ROOT_DOMAIN> (e.g. acme.arvidn.dev). Cloudflare zone = ROOT_DOMAIN apex (arvidn.dev).
# Panel UI hostname is separate: set PANEL_VIRTUAL_HOST in repo-root `.env` for docker-compose (e.g. wp.arvidn.dev).
ROOT_DOMAIN="example.com"
SERVER_PUBLIC_IP="203.0.113.10"

# Cloudflare orange-cloud (TLS at Cloudflare). Set false or 0 for DNS-only A records.
CLOUDFLARE_DNS_PROXIED=true

# Cloudflare: create an API Token (My Profile → API Tokens), NOT the Global API Key.
# Permissions: Zone → DNS → Edit, scoped to zone ROOT_DOMAIN (e.g. arvidn.dev). ZONE_ID = that zone’s Overview page.
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# Outbound SMTP (e.g. Brevo, Resend). Port 587 → STARTTLS → SMTP_SECURE=false. Port 465 → implicit TLS → SMTP_SECURE=true (mixing these causes OpenSSL “wrong version number”).
# Brevo: SMTP_USER = “Login” from SMTP & API (e.g. …@smtp-brevo.com); SMTP_PASS = the generated SMTP key (xsmtpsib-…), NOT the REST API key.
# SMTP_FROM address/domain must be verified in Brevo (Senders & IPs → Domains / Single sender).
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="WP Builder <noreply@your-verified-domain.com>"
