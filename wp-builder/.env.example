# Copy to .env and adjust. Never commit .env.

MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# Public hostnames (nginx-proxy uses VIRTUAL_HOST; TLS can terminate at Cloudflare).
WORDPRESS_HOST=blog.example.com

# Optional: force site URL after TLS/migrations (https URLs). Leave blank to use DB settings.
# WORDPRESS_HOME=https://blog.example.com
# WORDPRESS_SITEURL=https://blog.example.com

# Optional object cache: start Redis with `docker compose --profile redis up -d` then point your Redis plugin at host `redis`, port 6379.

# Backups (Linux/macOS/Git Bash): run from repo root — `./scripts/backup-db.sh` (writes gzip dumps under ./backups; cron example: daily `cd /path/to/repo && ./scripts/backup-db.sh`).
VIRTUAL_HOST="wp.arvidn.dev"