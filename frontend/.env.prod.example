# Copy to frontend/.env.prod on the server (not committed).
# NEXT_PUBLIC_* is inlined at Docker build time and available in the browser bundle.

NEXT_PUBLIC_SITE_URL=https://netmart.se
# API origin only is fine — `/api` is appended in the client if missing (Nest global prefix).
# You may also set the full base, e.g. https://api.netmart.se/api
NEXT_PUBLIC_API_URL=https://api.netmart.se

# nginx-proxy (or similar): public hostname and container listen port to forward to.
VIRTUAL_HOST=netmart.se
VIRTUAL_PORT=3000
