# Copy to frontend/.env.prod on the server (not committed).
# NEXT_PUBLIC_* is inlined at Docker build time and available in the browser bundle.

NEXT_PUBLIC_SITE_URL=https://devnex.arvidn.dev
NEXT_PUBLIC_API_URL=https://api-devnex.arvidn.dev

# nginx-proxy (or similar): public hostname and container listen port to forward to.
VIRTUAL_HOST=devnex.arvidn.dev
VIRTUAL_PORT=3000
