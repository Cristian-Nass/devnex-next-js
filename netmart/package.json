{
  "name": "netmart",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
    "dev:web": "npm run dev -w frontend",
    "dev:webpack": "npm run dev:webpack -w frontend",
    "dev:api": "npm run start:dev -w backend",
    "build": "npm run build -w frontend",
    "build:web": "npm run build -w frontend",
    "build:api": "npm run build -w backend",
    "start": "npm run start -w frontend",
    "start:api": "npm run start:prod -w backend",
    "migrate:dev": "npm run prisma:migrate:dev -w backend",
    "migrate:deploy": "npm run prisma:migrate:deploy -w backend",
    "lint": "npm run lint -w frontend",
    "lint:api": "npm run lint -w backend"
  }
}
