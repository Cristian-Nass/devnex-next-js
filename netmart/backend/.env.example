NODE_ENV=production
PORT=3001

# Use the Postgres *server* hostname (Compose service name, internal DNS, RDS host, etc.).
# Names like pgadmin-* are often the pgAdmin UI, not Postgres. From Docker, 127.0.0.1 is the container, not the host.
DATABASE_URL=postgres://user:pass@hostname:5432/dbname

# Prisma: after deploy, apply migrations (see docker-compose.yml).
JWT_SECRET=generate-a-long-random-secret
JWT_EXPIRATION=7d

# Cross-subdomain auth cookie (`netmart_session`). Set to a leading-dot apex
# so every sibling SaaS subdomain receives it automatically.
COOKIE_DOMAIN=.arvidn.dev

# Reverse-proxy (e.g. nginx-proxy): public hostname and container listen port nginx-proxy forwards to.
VIRTUAL_HOST=api-devnex.arvidn.dev
VIRTUAL_PORT=3001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Browser origin(s) allowed to call the API (comma-separated). Must match the public frontend URL.
CORS_ORIGIN=https://devnex.arvidn.dev
FRONTEND_URL=https://devnex.arvidn.dev


# Google OAuth — redirect URI must include /api (Nest global prefix).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api-devnex.arvidn.dev/api/auth/google/callback
