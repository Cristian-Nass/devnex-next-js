# Base URL of the web-builder API (include /api prefix). The viewer uses
# this for GET /sites/public/by-host/{hostname}. Previously pointed at the
# netmart backend; after the split the Site table lives in web-builder.
#
#   dev (local):    http://localhost:3001/api
#   dev (Docker):   http://web-builder:3001/api
#   prod:           https://builder.netmart.se/api
SITE_API_URL=http://localhost:3001/api
