{
  "name": "@netmart/builder-core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared block components, page renderer, and types used by web-builder (editor) and web-viewer (public renderer).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./editor": {
      "types": "./src/editor-types.ts",
      "default": "./src/editor-types.ts"
    }
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(no lint configured)\""
  },
  "devDependencies": {
    "@types/react": "^19",
    "react": "^19",
    "typescript": "^5"
  }
}
